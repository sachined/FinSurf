node_modules/
build/
dist/
coverage/
.DS_Store
*.log
.env*
!.env.example
!.env.nonsecret

# Secrets directory — never commit actual keys
# Use secrets/TEMPLATE/ instead
secrets/*.txt
!secrets/.gitkeep

# Runtime SQLite databases (generated at runtime; not part of the source tree)
*.db
*.db-wal
*.db-shm

# Python cache
__pycache__/
*.pyc
*.pyo

# Captured output artifacts
.output.txt
