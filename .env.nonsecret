# ─────────────────────────────────────────────────────────────────────────────
# .env.nonsecret — Non-sensitive environment variables only
# 
# This file contains only non-sensitive configuration. API keys and secrets
# are stored in Docker Secrets and mounted as files in /run/secrets/
# ─────────────────────────────────────────────────────────────────────────────

# ── Server Configuration ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Deployment — Production domain ───────────────────────────────────────────
# Used by docker-compose.prod.yml and Caddyfile to provision the TLS certificate.
# Example: DOMAIN=finsurf.example.com
DOMAIN=finsurf.net

# ── Telemetry & Cost Control ──────────────────────────────────────────────────
# Override the default SQLite path (useful in Docker where /app/data is a volume).
TELEMETRY_DB=/app/data/finsurf_telemetry.db

# Set to "true" to disable all telemetry writes (useful in CI or offline testing).
TELEMETRY_DISABLED=false

# Daily USD spend cap. If the last 24 h of telemetry exceeds this value,
# new graph runs are rejected with a 429-style error to protect your API balance.
# Leave blank or set to 0 to disable enforcement.
DAILY_BUDGET_USD=

# ── Provider Allowlist ────────────────────────────────────────────────────────
# Comma-separated list of enabled providers.
# Defaults: gemini,perplexity  (OpenAI and Anthropic are opt-in)
# Example:  ALLOWED_PROVIDERS=gemini,perplexity,openai,anthropic
ALLOWED_PROVIDERS=gemini,perplexity,groq
# ── LangSmith Tracing ──────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=FinSurf
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
