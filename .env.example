# ─────────────────────────────────────────────────────────────────────────────
# FinSurf environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Required — all agents fall back to Gemini if other providers are unavailable.
GEMINI_API_KEY=your_gemini_api_key_here
# Legacy alias — API_KEY is accepted as a fallback for GEMINI_API_KEY (read by backend/llm_providers.py).
# Prefer GEMINI_API_KEY; only set this if migrating from an older config.
# API_KEY=

# Optional — used for web-search-grounded research and sentiment analysis.
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Optional - used for a supported provider
GROQ_API_KEY=your_groq_api_key_here

# Optional — override the Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=
# ── Server Configuration ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Alpha Vantage — News & Sentiment ──────────────────────────────────────────
# Free API key at https://www.alphavantage.co/support/#api-key (instant signup).
# Used by the Social Sentiment agent for scored news articles per ticker.
# Free tier: 25 calls/day (results cached 1 hour per ticker).
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# ── Finnhub — Company news, insider transactions, earnings surprises ───────────
# Free API key at https://finnhub.io (instant signup, no credit card).
# Used by both the Sentiment agent (company news) and the Research agent
# (insider transactions, earnings surprises). Free tier: 60 req/min.
FINNHUB_API_KEY=your_finnhub_key_here

# ── Stripe — Payments ─────────────────────────────────────────────────────────
# Create a product + price in your Stripe dashboard, then copy the keys here.
# Use test keys (sk_test_...) locally — live keys only in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # From: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Baked into the Vite frontend bundle at build time (safe to expose — it's publishable):
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Resend — Transactional Email ──────────────────────────────────────────────
# Sign up at resend.com — free tier: 3 000 emails/month.
# Verify your sending domain (finsurf.ai) in the Resend dashboard for production.
# Until then, FROM_EMAIL can stay as onboarding@resend.dev for testing.
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev  # Change to noreply@yourdomain.com after domain verification

# ── App public URL (used in activation email links) ───────────────────────────
# Leave blank to derive from DOMAIN (e.g. https://finsurf.ai).
APP_URL=

# ── Security — Authentication ─────────────────────────────────────────────────
# When set, all /api/ routes require the header:  Authorization: Bearer <APP_SECRET>
# Generate a secure random value:  openssl rand -hex 32
APP_SECRET=

# Required for authenticated API calls from the frontend.
# Must match APP_SECRET exactly — the frontend fetch wrapper (src/utils/apiFetch.ts)
# automatically injects this as an  Authorization: Bearer  header on every API request.
# Baked into the Vite bundle at build time; supply as a Docker build-arg in production.
VITE_APP_SECRET=

# Admin panel secret — protects /admin routes locally and as a fallback to Cloudflare Access.
# Generate: openssl rand -hex 32
ADMIN_SECRET=

# Comma-separated VIP access codes (keep private — use the admin API to generate these).
# Example: VIP_PASSES=CODE1,CODE2,CODE3
VIP_PASSES=

# Path to the JSON file that stores admin-generated VIP passes.
# Defaults to vip_passes.json next to server.ts. Override for Docker volume mounts.
# Example: VIP_PASSES_FILE=/app/data/vip_passes.json
VIP_PASSES_FILE=

# Docker Secrets — *_FILE variants
# For each key above, server.ts also accepts a *_FILE variant pointing to a file containing the secret.
# This is the Docker Secrets pattern — the file contents are read at startup instead of the env var.
# Example: GEMINI_API_KEY_FILE=/run/secrets/gemini_key
# Supported: GEMINI_API_KEY_FILE, PERPLEXITY_API_KEY_FILE, GROQ_API_KEY_FILE,
#            APP_SECRET_FILE, ADMIN_SECRET_FILE, LANGCHAIN_API_KEY_FILE,
#            ALPHA_VANTAGE_API_KEY_FILE, FINNHUB_API_KEY_FILE

# ── Security — CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave blank to allow all origins (dev).
# Production example: CORS_ORIGIN=https://finsurf.example.com
CORS_ORIGIN=

# Set to "true" if the server is behind a TLS terminator that handles HTTPS.
# When true: enables HSTS headers. When false/unset: HSTS is disabled.
HTTPS=

# ── Deployment — Production domain ───────────────────────────────────────────
# Used by docker-compose.prod.yml and Caddyfile to provision the TLS certificate.
# Example: DOMAIN=finsurf.example.com
DOMAIN=

# ── Telemetry & Cost Control ──────────────────────────────────────────────────
# Override the default SQLite path (useful in Docker where /app/data is a volume).
TELEMETRY_DB=finsurf_telemetry.db

# Set to "true" to disable all telemetry writes (useful in CI or offline testing).
TELEMETRY_DISABLED=false

# Daily USD spend cap — PLANNED, not yet enforced.
# When implemented: if the last 24 h of telemetry exceeds this value,
# new graph runs will be rejected with a 429-style error to protect your API balance.
# Leave blank or set to 0 to disable enforcement (current behaviour regardless of value).
DAILY_BUDGET_USD=

# ── Provider Allowlist ────────────────────────────────────────────────────────
# Comma-separated list of enabled providers.
# Defaults: gemini,perplexity  (OpenAI and Anthropic are opt-in)
# Example:  ALLOWED_PROVIDERS=gemini,perplexity,openai,anthropic
ALLOWED_PROVIDERS=

# Individual provider toggles — alternative to ALLOWED_PROVIDERS for fine-grained control.
# Set to "true" to enable, "false" to disable. If unset, falls back to ALLOWED_PROVIDERS logic.
# ALLOW_GEMINI=true
# ALLOW_PERPLEXITY=true
# ALLOW_GROQ=true
# ALLOW_OPENAI=false
# ALLOW_ANTHROPIC=false

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=FinSurf
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Internal / Advanced ───────────────────────────────────────────────────────
# These are not normally set by operators — documented here for completeness.

# Set to "true" to bypass the security guardrail check on every agent call.
# Injected automatically by server.ts at runtime; do not set manually in production.
# SKIP_GUARDRAIL=false

# Set to "true" to disable Vite HMR (hot module replacement) during development.
# Used in AI Studio and headless environments where file-watch events cause flickering.
# DISABLE_HMR=false

# FINSURF_PASS_TYPE and FINSURF_COUNTRY are injected per-request by server.ts
# based on the validated VIP pass and request headers. Not operator-configurable.